{
  "name": "ichigojam-react",
  "version": "0.1.0",
  "description": "IchigoJam BASIC as a React component, running in WebAssembly.",
  "keywords": [
    "basic",
    "emulator",
    "ichigojam",
    "react",
    "retro",
    "wasm",
    "webassembly"
  ],
  "homepage": "https://github.com/Shiyo1101/ichigojam-react#readme",
  "license": "MIT",
  "author": "Shiyo1101",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shiyo1101/ichigojam-react.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "sync-wasm": "node scripts/sync-wasm.mjs",
    "build": "vite build",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepublishOnly": "pnpm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript/native-preview": "7.0.0-dev.20260703.1",
    "@vitejs/plugin-react": "^6.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint",
      "oxfmt"
    ],
    "*.{json,md,html}": "oxfmt"
  },
  "packageManager": "pnpm@11.9.0"
}
